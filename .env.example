# ─── App ──────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost/api/v1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=pharma_admin
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=pharmacy_platform

AUTH_DB_URL=postgresql+asyncpg://pharma_admin:changeme_in_production@postgres:5432/auth_db
INVENTORY_DB_URL=postgresql+asyncpg://pharma_admin:changeme_in_production@postgres:5432/inventory_db
BILLING_DB_URL=postgresql+asyncpg://pharma_admin:changeme_in_production@postgres:5432/billing_db
AI_DB_URL=postgresql+asyncpg://pharma_admin:changeme_in_production@postgres:5432/ai_db
REPORTING_DB_URL=postgresql+asyncpg://pharma_admin:changeme_in_production@postgres:5432/reporting_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-strong-256-bit-secret-here
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_ISSUER=PharmaCentral

# ─── AI Service ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─── Groq (fast LLM inference — recommended for real-time AI Console) ────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_PROVIDER=groq                   # groq | openai — which provider to use

AI_MAX_QUERY_ROWS=1000
AI_ENABLE_PII_MASKING=true

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=
GRAFANA_PASSWORD=changeme

# ─── Email (optional) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
